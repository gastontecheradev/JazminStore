@model ProductEditViewModel
@{
    ViewData["Title"] = "Nuevo producto";
}

<div class="admin-head">
    <h1>Nuevo producto</h1>
    <a asp-action="Index" class="btn btn-outline btn-sm">← Volver</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="adm-card">
    @Html.AntiForgeryToken()

    @await Html.PartialAsync("_FormFields", Model)

    <div class="form-field" style="margin-top:18px">
        <label asp-for="NewImages"></label>
        <input type="file" name="NewImages" multiple accept="image/*" />
        <div style="font-size:11px; color:var(--text-muted); margin-top:4px">
            Podés subir varias imágenes. La primera será la principal. Máximo 5MB cada una. Formatos: jpg, png, webp, gif.
        </div>
    </div>

    <div style="margin-top:20px; display:flex; gap:10px">
        <button type="submit" class="btn btn-primary">Crear producto</button>
        <a asp-action="Index" class="btn btn-ghost">Cancelar</a>
    </div>
</form>
