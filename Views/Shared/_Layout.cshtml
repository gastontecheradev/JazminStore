@{
    var siteName = Config["Site:Name"] ?? "JAZMÍN";
    var tagline = Config["Site:Tagline"] ?? "Ropa hecha con amor";
    var siteUrl = Config["Site:Url"] ?? "";
    var whatsApp = Config["Site:WhatsAppNumber"] ?? "";
    var whatsAppMsg = Config["Site:WhatsAppMessage"] ?? "Hola!";
    var instagram = Config["Site:Instagram"] ?? "";
    var instagramUrl = Config["Site:InstagramUrl"] ?? "";
    var contactEmail = Config["Site:ContactEmail"] ?? "";

    var title = ViewData["Title"]?.ToString();
    var metaDescription = ViewData["MetaDescription"]?.ToString() ?? $"{siteName} — {tagline}. Ropa femenina hecha a mano en Uruguay.";
    var metaImage = ViewData["MetaImage"]?.ToString() ?? $"{siteUrl}/img/og-cover.svg";
    var fullTitle = string.IsNullOrEmpty(title) ? $"{siteName} — {tagline}" : $"{title} · {siteName}";

    var cartCount = await CartSvc.GetItemCountAsync(Context);

    bool isAdminArea = (ViewContext.RouteData.Values["area"] as string) == "Admin";
    var currentController = ViewContext.RouteData.Values["controller"] as string;
    string NavClass(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
    var currentUser = SignInMgr.IsSignedIn(User) ? await UserMgr.GetUserAsync(User) : null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@fullTitle</title>
    <meta name="description" content="@metaDescription" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="@fullTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:image" content="@metaImage" />
    <meta property="og:site_name" content="@siteName" />
    <meta property="og:locale" content="es_UY" />
    @if (!string.IsNullOrEmpty(siteUrl))
    {
        <meta property="og:url" content="@siteUrl@Context.Request.Path" />
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@fullTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@metaImage" />

    <link rel="icon" type="image/svg+xml" href="~/img/favicon.svg" />
    <link rel="alternate icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" href="~/img/apple-touch-icon.png" />
    <meta name="theme-color" content="#FFF8F8" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (isAdminArea)
    {
        <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(isAdminArea ? "is-admin" : "")">
@if (isAdminArea)
{
    <div class="admin-shell">
        @await Html.PartialAsync("_AdminNav")
        <main class="admin-main">
            @if (TempData["AdminMessage"] != null)
            {
                <div class="alert alert-success">@TempData["AdminMessage"]</div>
            }
            @RenderBody()
        </main>
    </div>
}
else
{
    <nav class="nav">
        <a href="@Url.Action("Index", "Home")" class="nav-logo">@siteName</a>

        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index" class="@NavClass("Home")">Inicio</a>
            <a asp-controller="Catalog" asp-action="Index" class="@NavClass("Catalog")">Catálogo</a>
            <a asp-controller="Home" asp-action="About" class="nav-link">Sobre mí</a>
            <a asp-controller="Home" asp-action="Contact" class="nav-link">Contacto</a>
        </div>

        <div class="nav-right">
            <form asp-controller="Catalog" asp-action="Index" method="get" class="search-wrap" role="search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" name="search" placeholder="Buscar…" value="@(Context.Request.Query["search"])" />
            </form>

            @if (SignInMgr.IsSignedIn(User))
            {
                <a asp-controller="Favorites" asp-action="Index" class="icon-btn" title="Favoritos" aria-label="Favoritos">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </a>
            }

            <a asp-controller="Cart" asp-action="Index" class="icon-btn" title="Carrito" aria-label="Carrito">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                @if (cartCount > 0)
                {
                    <span class="badge">@cartCount</span>
                }
            </a>

            @if (SignInMgr.IsSignedIn(User))
            {
                <div class="user-menu">
                    <button type="button" class="icon-btn" aria-haspopup="true" aria-expanded="false" onclick="this.nextElementSibling.classList.toggle('open'); this.setAttribute('aria-expanded', this.nextElementSibling.classList.contains('open'))">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </button>
                    <div class="user-dropdown">
                        <div class="user-dd-head">Hola, @(currentUser?.FullName ?? "cuenta")</div>
                        <a asp-controller="Account" asp-action="Profile">Mi cuenta</a>
                        <a asp-controller="Order" asp-action="Index">Mis pedidos</a>
                        <a asp-controller="Favorites" asp-action="Index">Favoritos</a>
                        <a asp-controller="Account" asp-action="ChangePassword">Cambiar contraseña</a>
                        @if (User.IsInRole(Jazmin.Data.DbSeeder.AdminRole))
                        {
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Panel admin</a>
                        }
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="user-dd-logout">Cerrar sesión</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="nav-link" style="padding:6px 12px">Entrar</a>
            }
        </div>
    </nav>

    <main class="main-wrap">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="foot-grid">
            <div>
                <div class="foot-brand">@siteName</div>
                <p class="foot-text">@tagline. Cada prenda hecha a mano, pensada con cariño y única como vos.</p>
            </div>
            <div>
                <div class="foot-title">Navegación</div>
                <a asp-controller="Home" asp-action="Index" class="foot-link">Inicio</a>
                <a asp-controller="Catalog" asp-action="Index" class="foot-link">Catálogo</a>
                <a asp-controller="Home" asp-action="About" class="foot-link">Sobre mí</a>
                <a asp-controller="Home" asp-action="Contact" class="foot-link">Contacto</a>
            </div>
            <div>
                <div class="foot-title">Cuenta</div>
                @if (SignInMgr.IsSignedIn(User))
                {
                    <a asp-controller="Account" asp-action="Profile" class="foot-link">Mi cuenta</a>
                    <a asp-controller="Order" asp-action="Index" class="foot-link">Mis pedidos</a>
                    <a asp-controller="Favorites" asp-action="Index" class="foot-link">Favoritos</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="foot-link">Iniciar sesión</a>
                    <a asp-controller="Account" asp-action="Register" class="foot-link">Crear cuenta</a>
                }
            </div>
            <div>
                <div class="foot-title">Contacto</div>
                @if (!string.IsNullOrEmpty(whatsApp))
                {
                    <a href="https://wa.me/@whatsApp?text=@Uri.EscapeDataString(whatsAppMsg)" target="_blank" rel="noopener" class="foot-link">
                        <span class="foot-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M20.52 3.48A11.86 11.86 0 0 0 12.02 0C5.4 0 .02 5.38 0 12c0 2.1.55 4.15 1.6 5.96L0 24l6.2-1.62a12 12 0 0 0 5.82 1.48h.01c6.6 0 12-5.38 12-12 0-3.2-1.25-6.22-3.51-8.38zm-8.5 18.4h-.01a9.94 9.94 0 0 1-5.06-1.38l-.36-.22-3.68.96.98-3.58-.23-.37A9.93 9.93 0 0 1 2 12c0-5.52 4.5-10 10.02-10 2.68 0 5.2 1.04 7.1 2.93a9.93 9.93 0 0 1 2.94 7.08c0 5.52-4.5 10-10.04 10z"/></svg>
                        </span>
                        WhatsApp
                    </a>
                }
                @if (!string.IsNullOrEmpty(instagramUrl))
                {
                    <a href="@instagramUrl" target="_blank" rel="noopener" class="foot-link">
                        <span class="foot-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                        </span>
                        @@@instagram
                    </a>
                }
                @if (!string.IsNullOrEmpty(contactEmail))
                {
                    <a href="mailto:@contactEmail" class="foot-link">
                        <span class="foot-icon">✉</span> @contactEmail
                    </a>
                }
            </div>
        </div>
        <div class="foot-bottom">© @DateTime.Now.Year @siteName — Hecho con amor ♥</div>
    </footer>

    @if (!string.IsNullOrEmpty(whatsApp))
    {
        <a href="https://wa.me/@whatsApp?text=@Uri.EscapeDataString(whatsAppMsg)" target="_blank" rel="noopener" class="wa-float" aria-label="Escribir por WhatsApp" title="WhatsApp">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M20.52 3.48A11.86 11.86 0 0 0 12.02 0C5.4 0 .02 5.38 0 12c0 2.1.55 4.15 1.6 5.96L0 24l6.2-1.62a12 12 0 0 0 5.82 1.48h.01c6.6 0 12-5.38 12-12 0-3.2-1.25-6.22-3.51-8.38zm-8.5 18.4h-.01a9.94 9.94 0 0 1-5.06-1.38l-.36-.22-3.68.96.98-3.58-.23-.37A9.93 9.93 0 0 1 2 12c0-5.52 4.5-10 10.02-10 2.68 0 5.2 1.04 7.1 2.93a9.93 9.93 0 0 1 2.94 7.08c0 5.52-4.5 10-10.04 10z"/></svg>
        </a>
    }
}

@if (TempData["CartMessage"] != null)
{
    <div class="toast" id="toast-auto">@TempData["CartMessage"]</div>
    <script>setTimeout(()=>{const t=document.getElementById('toast-auto'); if(t) t.remove();}, 2800);</script>
}

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
