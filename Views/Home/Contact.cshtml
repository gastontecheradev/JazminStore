@{
    ViewData["Title"] = "Contacto";
    var whatsApp = Config["Site:WhatsAppNumber"] ?? "";
    var whatsAppMsg = Config["Site:WhatsAppMessage"] ?? "Hola!";
    var instagram = Config["Site:Instagram"] ?? "";
    var instagramUrl = Config["Site:InstagramUrl"] ?? "";
    var contactEmail = Config["Site:ContactEmail"] ?? "";
}

<section class="section container-narrow" style="text-align:center">
    <div class="section-eyebrow">Escribinos</div>
    <h1 class="section-title">Contacto</h1>
    <p class="section-sub">Estamos a un mensaje de distancia. Respondemos en el día.</p>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:18px; margin-top:40px">
        @if (!string.IsNullOrEmpty(whatsApp))
        {
            <a href="https://wa.me/@whatsApp?text=@Uri.EscapeDataString(whatsAppMsg)" target="_blank" rel="noopener" class="cat-card" style="background:#E7F8EE; border-color:#C8E8D3">
                <div class="cat-card-title" style="color:#25D366">WhatsApp</div>
                <div class="cat-card-count">La vía más rápida</div>
            </a>
        }
        @if (!string.IsNullOrEmpty(instagramUrl))
        {
            <a href="@instagramUrl" target="_blank" rel="noopener" class="cat-card">
                <div class="cat-card-title">Instagram</div>
                <div class="cat-card-count">@@@instagram</div>
            </a>
        }
        @if (!string.IsNullOrEmpty(contactEmail))
        {
            <a href="mailto:@contactEmail" class="cat-card">
                <div class="cat-card-title">Email</div>
                <div class="cat-card-count">@contactEmail</div>
            </a>
        }
    </div>

    <p style="margin-top:48px; color:var(--text-muted); font-size:13px">Hacemos envíos a todo Uruguay · Retiro en persona disponible</p>
</section>
