@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.Name;
    ViewData["MetaDescription"] = Model.Product.ShortDescription ?? Model.Product.Description ?? Model.Product.Name;
    var hasDiscount = Model.Product.ComparePrice.HasValue && Model.Product.ComparePrice.Value > Model.Product.Price;
    var sizes = Model.Product.GetSizes();
    var images = Model.Product.Images.OrderByDescending(i => i.IsPrimary).ThenBy(i => i.SortOrder).ToList();
    var primaryImg = images.FirstOrDefault()?.Url ?? "/img/placeholder.svg";
    var isLoggedIn = SignInMgr.IsSignedIn(User);
    var isOut = Model.Product.Stock == 0;
}

<div class="pd-wrap">
    <div class="pd-gallery">
        <div class="pd-main-img">
            <img src="@primaryImg" alt="@Model.Product.Name" id="pd-main-img" />
        </div>
        @if (images.Count > 1)
        {
            <div class="pd-thumbs">
                @for (int i = 0; i < images.Count; i++)
                {
                    var img = images[i];
                    <button type="button" class="pd-thumb @(i == 0 ? "active" : "")" data-src="@img.Url" aria-label="Imagen @(i + 1)">
                        <img src="@img.Url" alt="@(img.Alt ?? Model.Product.Name)" />
                    </button>
                }
            </div>
        }
    </div>

    <div class="pd-info">
        <div class="pd-cat">@Model.Product.Category?.Name</div>
        <h1 class="pd-title">@Model.Product.Name</h1>

        @if (Model.ReviewCount > 0)
        {
            <div class="pd-rating">
                <span class="stars">@Html.Raw(string.Concat(Enumerable.Range(1, 5).Select(i => i <= Math.Round(Model.AverageRating) ? "★" : "☆")))</span>
                <span>@Model.AverageRating.ToString("0.0") · @Model.ReviewCount reseñ@(Model.ReviewCount == 1 ? "a" : "as")</span>
            </div>
        }

        <div class="pd-price-row">
            <span class="pd-price">$ @Model.Product.Price.ToString("N0")</span>
            @if (hasDiscount)
            {
                <span class="pd-compare">$ @Model.Product.ComparePrice!.Value.ToString("N0")</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Product.ShortDescription))
        {
            <div style="font-size:14px; color:var(--text-muted); line-height:1.7">@Model.Product.ShortDescription</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Product.Description))
        {
            <div class="pd-desc">@Model.Product.Description</div>
        }

        <form asp-controller="Cart" asp-action="Add" method="post" class="js-cart-add">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.Product.Id" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

            @if (sizes.Length > 1)
            {
                <div style="margin-top:14px">
                    <div class="pd-label">Talla</div>
                    <div class="size-options">
                        @for (int i = 0; i < sizes.Length; i++)
                        {
                            <label class="size-option @(i == 0 ? "active" : "")">
                                <input type="radio" name="size" value="@sizes[i]" checked="@(i == 0)" />
                                @sizes[i]
                            </label>
                        }
                    </div>
                </div>
            }
            else if (sizes.Length == 1)
            {
                <input type="hidden" name="size" value="@sizes[0]" />
            }

            <div style="margin-top:16px; display:flex; gap:10px; align-items:center; flex-wrap:wrap">
                <div class="pd-qty">
                    <button type="button" data-qty="minus" aria-label="Menos">−</button>
                    <input type="number" name="qty" value="1" min="1" max="@Model.Product.Stock" />
                    <button type="button" data-qty="plus" aria-label="Más">+</button>
                </div>
                <button type="submit" class="btn btn-primary btn-lg" @(isOut ? "disabled" : "")>
                    @(isOut ? "Sin stock" : "Agregar al carrito")
                </button>
                @if (isLoggedIn)
                {
                    <form asp-controller="Favorites" asp-action="Toggle" method="post" class="js-fav-toggle" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Product.Id" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <button type="submit" class="fav-btn @(Model.IsFavorite ? "is-fav" : "")" aria-label="Favorito" title="@(Model.IsFavorite ? "Quitar de favoritos" : "Agregar a favoritos")">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="@(Model.IsFavorite ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </form>
                }
            </div>
            <div class="pd-stock @(isOut ? "out" : "")" style="margin-top:10px">
                @(isOut ? "Sin stock por el momento." : (Model.Product.Stock < 5 ? $"¡Solo quedan {Model.Product.Stock}!" : "En stock"))
            </div>
        </form>
    </div>
</div>

<!-- REVIEWS SECTION -->
<section class="reviews-section">
    <div class="reviews-head">
        <h2 class="reviews-title">Reseñas</h2>
        @if (Model.ReviewCount > 0)
        {
            <span class="pd-rating">
                <span class="stars">@Html.Raw(string.Concat(Enumerable.Range(1, 5).Select(i => i <= Math.Round(Model.AverageRating) ? "★" : "☆")))</span>
                <span>@Model.AverageRating.ToString("0.0") de 5 · @Model.ReviewCount</span>
            </span>
        }
    </div>

    @if (Model.CanReview)
    {
        <form asp-controller="Order" asp-action="ReviewProduct" method="post" class="review-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="orderId" value="@Model.PurchasedOrderId" />
            <input type="hidden" name="productId" value="@Model.Product.Id" />
            <h3>Compraste esta prenda — contanos cómo te fue</h3>
            <div style="margin-bottom:14px">
                <div class="pd-label">Tu calificación</div>
                <div class="rating-input">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <input type="radio" name="rating" value="@i" id="rating-@i" required />
                        <label for="rating-@i" data-v="@i">★</label>
                    }
                </div>
            </div>
            <div>
                <div class="pd-label">Tu comentario (opcional)</div>
                <textarea name="comment" rows="3" maxlength="1500" placeholder="Contanos qué te pareció la prenda, el talle, la calidad..."></textarea>
            </div>
            <div style="margin-top:12px">
                <button type="submit" class="btn btn-primary">Publicar reseña</button>
            </div>
        </form>
    }
    else if (!isLoggedIn)
    {
        <div class="alert alert-info">
            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">Iniciá sesión</a>
            para dejar una reseña si ya compraste esta prenda.
        </div>
    }

    @if (Model.Reviews.Any())
    {
        <div class="reviews-grid">
            @foreach (var r in Model.Reviews)
            {
                <div class="review">
                    <div class="review-head">
                        <div>
                            <span class="review-author">@(r.User?.FullName ?? "Clienta")</span>
                            <span class="review-stars" style="margin-left:8px">@Html.Raw(string.Concat(Enumerable.Range(1, 5).Select(i => i <= r.Rating ? "★" : "☆")))</span>
                        </div>
                        <span class="review-date">@r.CreatedAt.ToString("dd 'de' MMMM 'de' yyyy")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(r.Comment))
                    {
                        <div class="review-comment">@r.Comment</div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <p style="color:var(--text-muted); text-align:center; padding:30px 0">
            Todavía no hay reseñas. ¡Sé la primera!
        </p>
    }
</section>

@if (Model.Related.Any())
{
    <section class="section">
        <div class="section-head">
            <h2 class="section-title">También podría gustarte</h2>
        </div>
        <div class="grid-products">
            @foreach (var p in Model.Related)
            {
                var vdRel = new ViewDataDictionary(ViewData);
                vdRel["Ratings"] = Model.RelatedRatings;
                vdRel["Favorites"] = new HashSet<int>();
                @await Html.PartialAsync("_ProductCard", p, vdRel)
            }
        </div>
    </section>
}
