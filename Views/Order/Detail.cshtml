@model Jazmin.Models.Order
@using Jazmin.Data
@using Jazmin.Models
@inject ApplicationDbContext DbCtx
@{
    ViewData["Title"] = $"Pedido {Model.OrderNumber}";
    var canRateOrder = Model.Status == OrderStatus.Delivered && !Model.Rating.HasValue;
    var canReview = Model.Status == OrderStatus.Delivered;
    // Pre-fetch existing reviews per product for this order (best done in controller, but keeping simple here)
    var uid = UserMgr.GetUserId(User);
    var reviewedProductIds = canReview
        ? DbCtx.Reviews.Where(r => r.OrderId == Model.Id && r.UserId == uid).Select(r => r.ProductId).ToHashSet()
        : new HashSet<int>();
}

<section class="order-detail">
    @if (TempData["OrderMessage"] != null)
    {
        <div class="alert alert-success">@TempData["OrderMessage"]</div>
    }

    <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px; margin-bottom:20px">
        <div>
            <h1 style="font-family:var(--serif); font-size:34px; color:var(--pink-700); font-style:italic">Pedido @Model.OrderNumber</h1>
            <div style="color:var(--text-muted); font-size:13px; margin-top:4px">@Model.CreatedAt.ToLocalTime().ToString("dd 'de' MMMM 'de' yyyy, HH:mm")</div>
        </div>
        <span class="status status-@Model.Status" style="font-size:12px; padding:6px 14px">@Model.Status</span>
    </div>

    <div style="background:white; border:1px solid var(--border); border-radius:var(--r); padding:24px; margin-bottom:18px">
        <h3 style="font-family:var(--serif); color:var(--pink-700); font-style:italic; font-size:22px; margin-bottom:14px">Productos</h3>

        @foreach (var item in Model.Items)
        {
            var isReviewed = reviewedProductIds.Contains(item.ProductId);
            <div style="display:grid; grid-template-columns:70px 1fr auto; gap:14px; padding:12px 0; border-bottom:1px solid var(--border)">
                <div style="width:70px; height:88px; background:var(--pink-50); border-radius:6px; overflow:hidden">
                    <img src="@(item.Product?.PrimaryImageUrl ?? "/img/placeholder.svg")" alt="@item.ProductName" style="width:100%;height:100%;object-fit:cover" />
                </div>
                <div>
                    <div style="font-family:var(--serif); font-size:17px; color:var(--text); font-weight:500">
                        @if (item.Product != null)
                        {
                            <a asp-controller="Product" asp-action="Detail" asp-route-slug="@item.Product.Slug" style="color:inherit">@item.ProductName</a>
                        }
                        else
                        {
                            @item.ProductName
                        }
                    </div>
                    <div style="font-size:12px; color:var(--text-muted); margin-top:4px">
                        @(!string.IsNullOrEmpty(item.Size) ? $"Talla {item.Size} · " : "")Cant: @item.Quantity · $ @item.UnitPrice.ToString("N0") c/u
                    </div>

                    @if (canReview && item.Product != null)
                    {
                        if (isReviewed)
                        {
                            <div style="margin-top:8px; font-size:12px; color:var(--success)">✓ Ya reseñaste este producto</div>
                        }
                        else
                        {
                            <details style="margin-top:10px">
                                <summary style="cursor:pointer; font-size:12px; color:var(--pink-700); font-weight:600">Dejar reseña</summary>
                                <form asp-controller="Order" asp-action="ReviewProduct" method="post" style="margin-top:10px; background:var(--pink-50); border-radius:var(--r-sm); padding:14px">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@Model.Id" />
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <div style="margin-bottom:10px">
                                        <div class="pd-label">Calificación</div>
                                        <div class="rating-input">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <input type="radio" name="rating" value="@i" id="rev-@item.Id-@i" required />
                                                <label for="rev-@item.Id-@i" data-v="@i">★</label>
                                            }
                                        </div>
                                    </div>
                                    <textarea name="comment" rows="2" maxlength="1500" placeholder="Tu comentario (opcional)"></textarea>
                                    <button type="submit" class="btn btn-primary btn-sm" style="margin-top:10px">Publicar</button>
                                </form>
                            </details>
                        }
                    }
                </div>
                <div style="font-weight:600; color:var(--pink-700); text-align:right">$ @item.LineTotal.ToString("N0")</div>
            </div>
        }

        <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:14px">
            <div style="text-align:right">
                <div style="font-size:13px; color:var(--text-muted); padding:3px 0">Subtotal: <strong style="color:var(--text)">$ @Model.Subtotal.ToString("N0")</strong></div>
                <div style="font-size:13px; color:var(--text-muted); padding:3px 0">Envío: <strong style="color:var(--text)">$ @Model.ShippingCost.ToString("N0")</strong></div>
                <div style="font-size:20px; font-weight:600; color:var(--pink-700); padding:6px 0 0; border-top:1px solid var(--border); margin-top:6px">Total: $ @Model.Total.ToString("N0")</div>
            </div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:18px">
        <div style="background:white; border:1px solid var(--border); border-radius:var(--r); padding:20px">
            <h3 style="font-family:var(--serif); color:var(--pink-700); font-style:italic; font-size:20px; margin-bottom:10px">Envío</h3>
            <div style="font-size:13px; line-height:1.8">
                <strong>@Model.CustomerName</strong><br/>
                @Model.CustomerPhone<br/>
                @Model.CustomerEmail<br/>
                @if (Model.ShippingZone != ShippingZone.Pickup)
                {
                    <text>@Model.ShippingAddress<br/></text>
                    <text>@Model.ShippingCity, @Model.ShippingDepartment</text>
                    if (!string.IsNullOrEmpty(Model.ShippingPostalCode))
                    {
                        <text> (CP @Model.ShippingPostalCode)</text>
                    }
                }
                else
                {
                    <text>Retiro en persona</text>
                }
            </div>
        </div>

        <div style="background:white; border:1px solid var(--border); border-radius:var(--r); padding:20px">
            <h3 style="font-family:var(--serif); color:var(--pink-700); font-style:italic; font-size:20px; margin-bottom:10px">Pago</h3>
            <div style="font-size:13px">
                @switch (Model.PaymentMethod)
                {
                    case PaymentMethod.MercadoPago:
                        <text>Mercado Pago</text>
                        if (!string.IsNullOrEmpty(Model.PaymentReference))
                        {
                            <div style="color:var(--text-muted); font-size:11px">Ref: @Model.PaymentReference</div>
                        }
                        break;
                    case PaymentMethod.CashOnDelivery:
                        <text>Efectivo contra entrega / acordar con vendedora</text>
                        break;
                    case PaymentMethod.BankTransfer:
                        <text>Transferencia bancaria</text>
                        <div style="margin-top:8px; color:var(--text-muted); font-size:12px">Te vamos a enviar los datos bancarios por email/WhatsApp.</div>
                        break;
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div style="margin-top:14px; padding-top:14px; border-top:1px solid var(--border); font-size:12px">
                    <strong>Notas:</strong> @Model.Notes
                </div>
            }
        </div>
    </div>

    @if (Model.Status == OrderStatus.Delivered)
    {
        <div style="background:white; border:1px solid var(--border); border-radius:var(--r); padding:22px; margin-top:18px">
            <h3 style="font-family:var(--serif); color:var(--pink-700); font-style:italic; font-size:22px; margin-bottom:12px">
                @(Model.Rating.HasValue ? "Tu calificación" : "Calificá tu experiencia")
            </h3>

            @if (Model.Rating.HasValue)
            {
                <div style="font-size:22px; color:var(--warning); margin-bottom:6px">
                    @Html.Raw(string.Concat(Enumerable.Range(1, 5).Select(i => i <= Model.Rating!.Value ? "★" : "☆")))
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.RatingComment))
                {
                    <div style="color:var(--text); font-size:14px; line-height:1.6">@Model.RatingComment</div>
                }
                <div style="font-size:12px; color:var(--text-muted); margin-top:6px">Calificado el @Model.RatedAt?.ToLocalTime().ToString("dd/MM/yyyy")</div>
            }
            else
            {
                <form asp-action="Rate" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <div class="rating-input">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <input type="radio" name="rating" value="@i" id="orderr-@i" required />
                            <label for="orderr-@i" data-v="@i">★</label>
                        }
                    </div>
                    <textarea name="comment" rows="3" maxlength="1000" placeholder="Contanos cómo fue la experiencia (opcional)" style="margin-top:12px"></textarea>
                    <button type="submit" class="btn btn-primary" style="margin-top:12px">Calificar</button>
                </form>
            }
        </div>
    }

    <div style="margin-top:24px">
        <a asp-action="Index" class="btn btn-outline">← Volver a mis pedidos</a>
    </div>
</section>
