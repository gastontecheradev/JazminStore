@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    var departments = ViewBag.Departments as IReadOnlyList<string> ?? new List<string>();
    var mpEnabled = ViewBag.MpEnabled as bool? ?? false;
    var mvdRate = Model.Cart.Subtotal > 0 ? Model.ShippingCost : 0m;
}

<div class="checkout-wrap">
    <form asp-action="Place" method="post" id="checkout-form">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(excludePropertyErrors: true, message: null, htmlAttributes: new { @class = "validation-summary-errors" })

        <!-- DATOS DE CONTACTO -->
        <div class="checkout-card">
            <h3>Datos de contacto</h3>
            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="CustomerName"></label>
                    <input asp-for="CustomerName" />
                    <span asp-validation-for="CustomerName" class="field-validation-error"></span>
                </div>
                <div class="form-field">
                    <label asp-for="CustomerEmail"></label>
                    <input asp-for="CustomerEmail" type="email" />
                    <span asp-validation-for="CustomerEmail" class="field-validation-error"></span>
                </div>
                <div class="form-field">
                    <label asp-for="CustomerPhone"></label>
                    <input asp-for="CustomerPhone" type="tel" placeholder="+598 99 123 456" />
                    <span asp-validation-for="CustomerPhone" class="field-validation-error"></span>
                </div>
            </div>
        </div>

        <!-- ENVÍO -->
        <div class="checkout-card">
            <h3>Envío</h3>
            <div class="zone-options">
                <label class="option-radio @(Model.ShippingZone == ShippingZone.Montevideo ? "active" : "")">
                    <input type="radio" name="ShippingZone" value="Montevideo" checked="@(Model.ShippingZone == ShippingZone.Montevideo)" onchange="toggleShippingFields(this)" />
                    <div>
                        <div class="opt-label">Envío a Montevideo</div>
                        <div class="opt-sub">Entrega en 1–3 días hábiles</div>
                    </div>
                    <span class="opt-price">$ @(Config.GetValue<decimal>("Shipping:MontevideoRate").ToString("N0"))</span>
                </label>
                <label class="option-radio @(Model.ShippingZone == ShippingZone.Interior ? "active" : "")">
                    <input type="radio" name="ShippingZone" value="Interior" checked="@(Model.ShippingZone == ShippingZone.Interior)" onchange="toggleShippingFields(this)" />
                    <div>
                        <div class="opt-label">Envío al Interior</div>
                        <div class="opt-sub">Por agencia a todo el país</div>
                    </div>
                    <span class="opt-price">$ @(Config.GetValue<decimal>("Shipping:InteriorRate").ToString("N0"))</span>
                </label>
                <label class="option-radio @(Model.ShippingZone == ShippingZone.Pickup ? "active" : "")">
                    <input type="radio" name="ShippingZone" value="Pickup" checked="@(Model.ShippingZone == ShippingZone.Pickup)" onchange="toggleShippingFields(this)" />
                    <div>
                        <div class="opt-label">Retiro en persona</div>
                        <div class="opt-sub">Coordinamos por WhatsApp</div>
                    </div>
                    <span class="opt-price">Gratis</span>
                </label>
            </div>

            <div id="shipping-fields" style="margin-top:16px; @(Model.ShippingZone == ShippingZone.Pickup ? "display:none" : "")">
                <div class="form-grid one-col">
                    <div class="form-field">
                        <label asp-for="ShippingAddress"></label>
                        <input asp-for="ShippingAddress" placeholder="Calle y número, apartamento" />
                        <span asp-validation-for="ShippingAddress" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-grid" style="margin-top:12px">
                    <div class="form-field">
                        <label asp-for="ShippingCity"></label>
                        <input asp-for="ShippingCity" />
                        <span asp-validation-for="ShippingCity" class="field-validation-error"></span>
                    </div>
                    <div class="form-field">
                        <label asp-for="ShippingDepartment"></label>
                        <select asp-for="ShippingDepartment">
                            <option value="">— Seleccioná —</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d" selected="@(Model.ShippingDepartment == d)">@d</option>
                            }
                        </select>
                        <span asp-validation-for="ShippingDepartment" class="field-validation-error"></span>
                    </div>
                    <div class="form-field">
                        <label asp-for="ShippingPostalCode"></label>
                        <input asp-for="ShippingPostalCode" />
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGO -->
        <div class="checkout-card">
            <h3>Método de pago</h3>
            <div class="payment-options">
                @if (mpEnabled)
                {
                    <label class="option-radio @(Model.PaymentMethod == PaymentMethod.MercadoPago ? "active" : "")">
                        <input type="radio" name="PaymentMethod" value="MercadoPago" checked="@(Model.PaymentMethod == PaymentMethod.MercadoPago)" />
                        <div>
                            <div class="opt-label">Mercado Pago</div>
                            <div class="opt-sub">Tarjeta, transferencia, saldo MP</div>
                        </div>
                    </label>
                }
                <label class="option-radio @(Model.PaymentMethod == PaymentMethod.CashOnDelivery ? "active" : "")">
                    <input type="radio" name="PaymentMethod" value="CashOnDelivery" checked="@(Model.PaymentMethod == PaymentMethod.CashOnDelivery)" />
                    <div>
                        <div class="opt-label">Efectivo contra entrega</div>
                        <div class="opt-sub">Coordinamos con la vendedora</div>
                    </div>
                </label>
                <label class="option-radio @(Model.PaymentMethod == PaymentMethod.BankTransfer ? "active" : "")">
                    <input type="radio" name="PaymentMethod" value="BankTransfer" checked="@(Model.PaymentMethod == PaymentMethod.BankTransfer)" />
                    <div>
                        <div class="opt-label">Transferencia bancaria</div>
                        <div class="opt-sub">Te enviamos los datos al confirmar</div>
                    </div>
                </label>
            </div>
        </div>

        <!-- NOTAS -->
        <div class="checkout-card">
            <h3>Notas para la vendedora (opcional)</h3>
            <textarea asp-for="Notes" rows="3" maxlength="500" placeholder="Ej: prefiero que llames antes de despachar"></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg btn-block">Confirmar pedido</button>
    </form>

    <aside class="summary">
        <h3>Tu pedido</h3>
        @foreach (var l in Model.Cart.Lines)
        {
            <div style="display:flex; gap:10px; padding:8px 0; border-bottom:1px solid var(--border)">
                <div style="width:56px;height:70px;background:var(--pink-50);border-radius:6px;overflow:hidden;flex-shrink:0">
                    <img src="@l.ImageUrl" alt="@l.ProductName" style="width:100%;height:100%;object-fit:cover" />
                </div>
                <div style="flex:1; min-width:0">
                    <div style="font-family:var(--serif);font-size:15px;color:var(--text)">@l.ProductName</div>
                    <div style="font-size:11px;color:var(--text-muted)">@(!string.IsNullOrEmpty(l.Size) ? $"Talla {l.Size} · " : "")Cant: @l.Quantity</div>
                </div>
                <div style="font-weight:600;font-size:13px;color:var(--pink-700)">$ @l.LineTotal.ToString("N0")</div>
            </div>
        }

        <div class="summary-row" style="margin-top:10px">
            <span>Subtotal</span>
            <span>$ @Model.Cart.Subtotal.ToString("N0")</span>
        </div>
        <div class="summary-row">
            <span>Envío</span>
            <span id="ship-cost">$ @mvdRate.ToString("N0")</span>
        </div>
        <div class="summary-row total">
            <span>Total</span>
            <span id="total-cost">$ @((Model.Cart.Subtotal + mvdRate).ToString("N0"))</span>
        </div>
    </aside>
</div>

@section Scripts {
<script>
    var mvdRate = @(Config.GetValue<decimal>("Shipping:MontevideoRate"));
    var interiorRate = @(Config.GetValue<decimal>("Shipping:InteriorRate"));
    var subtotal = @Model.Cart.Subtotal;

    function fmt(n) { return n.toLocaleString('es-UY', { maximumFractionDigits: 0 }); }

    function toggleShippingFields(radio) {
        var val = radio.value;
        var fields = document.getElementById('shipping-fields');
        fields.style.display = (val === 'Pickup') ? 'none' : '';
        var rate = val === 'Montevideo' ? mvdRate : (val === 'Interior' ? interiorRate : 0);
        document.getElementById('ship-cost').textContent = '$ ' + fmt(rate);
        document.getElementById('total-cost').textContent = '$ ' + fmt(subtotal + rate);
    }
</script>
}
