@{
    ViewData["Title"] = "Revisá tu email";
}

<div class="auth-wrap">
    <h1>Revisá tu email</h1>
    <p class="sub">
        Si existe una cuenta con ese email, te enviamos un enlace para restablecer tu contraseña.
        El enlace es válido por un tiempo limitado.
    </p>

    <div class="auth-footer">
        <a asp-action="Login" class="btn btn-outline btn-block" style="margin-top:14px">Volver al inicio de sesión</a>
    </div>
</div>
