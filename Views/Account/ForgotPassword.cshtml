@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="auth-wrap">
    <h1>¿Olvidaste tu contraseña?</h1>
    <p class="sub">Ingresá tu email y te enviamos un enlace para restablecerla</p>

    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()
        <div class="form-field">
            <label asp-for="Email"></label>
            <input asp-for="Email" type="email" autofocus />
            <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Enviar enlace</button>
    </form>

    <div class="auth-footer">
        <a asp-action="Login">Volver a iniciar sesión</a>
    </div>
</div>
