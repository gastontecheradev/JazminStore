@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="profile-wrap">
    <aside class="profile-side">
        <a asp-action="Profile">Mis datos</a>
        <a asp-controller="Order" asp-action="Index">Mis pedidos</a>
        <a asp-controller="Favorites" asp-action="Index">Favoritos</a>
        <a asp-action="ChangePassword" class="active">Cambiar contraseña</a>
    </aside>

    <div class="profile-main">
        <h2>Cambiar contraseña</h2>

        @if (TempData["ProfileMessage"] != null)
        {
            <div class="alert alert-success">@TempData["ProfileMessage"]</div>
        }

        <form asp-action="ChangePassword" method="post" style="max-width:400px">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(excludePropertyErrors: true, message: null, htmlAttributes: new { @class = "validation-summary-errors" })

            <div class="form-field" style="margin-bottom:14px">
                <label asp-for="OldPassword"></label>
                <input asp-for="OldPassword" type="password" autocomplete="current-password" />
                <span asp-validation-for="OldPassword" class="field-validation-error"></span>
            </div>
            <div class="form-field" style="margin-bottom:14px">
                <label asp-for="NewPassword"></label>
                <input asp-for="NewPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>
            <div class="form-field" style="margin-bottom:14px">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary">Actualizar contraseña</button>
        </form>
    </div>
</div>
